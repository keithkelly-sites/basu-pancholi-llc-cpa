---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'Basu Pancholi LLC CPA. Pittsburgh certified public accountants offering taxes, bookkeeping, payroll, IRS representation, and business consulting. Located in Upper St. Clair, South Hills.', ogImage } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = Astro.site?.href ?? 'https://basu-pancholi-llc-cpa.keithkelly.dev';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Basu Pancholi LLC CPA" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <title>{title}</title>
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <Font cssVariable="--font-mono" preload />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <a href="/" class="logo" aria-label="Basu Pancholi LLC — Home">
          <span class="logo-mark">B<span class="logo-bar">|</span>P</span>
          <span class="logo-text">Basu Pancholi</span>
        </a>

        <button
          class="menu-toggle"
          aria-expanded="false"
          aria-controls="main-nav"
          aria-label="Toggle navigation menu"
        >
          <span class="menu-bar"></span>
          <span class="menu-bar"></span>
        </button>

        <nav id="main-nav" class="main-nav" aria-label="Main navigation">
          <ul class="nav-list">
            <li><a href="/" class:list={[{ active: currentPath === '/' }]} aria-current={currentPath === '/' ? 'page' : undefined}>Home</a></li>
            <li><a href="/services" class:list={[{ active: currentPath === '/services' }]} aria-current={currentPath === '/services' ? 'page' : undefined}>Services</a></li>
            <li><a href="/indian-investors" class:list={[{ active: currentPath === '/indian-investors' }]} aria-current={currentPath === '/indian-investors' ? 'page' : undefined}>Indian Investors</a></li>
            <li><a href="/about" class:list={[{ active: currentPath === '/about' }]} aria-current={currentPath === '/about' ? 'page' : undefined}>About</a></li>
            <li><a href="/contact" class:list={[{ active: currentPath === '/contact' }]} aria-current={currentPath === '/contact' ? 'page' : undefined}>Contact</a></li>
          </ul>
          <a href="tel:4127201313" class="nav-cta btn btn--gold">412-720-1313</a>
        </nav>
      </div>
    </header>

    <main id="main-content">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="bridge-line"></div>
      <div class="container footer-grid">
        <div class="footer-brand">
          <span class="logo-mark footer-logo">B<span class="logo-bar">|</span>P</span>
          <p class="footer-tagline">The bridge between you<br />and your success.</p>
        </div>

        <div class="footer-col">
          <p class="footer-heading">Services</p>
          <ul>
            <li><a href="/services#taxes">Taxes</a></li>
            <li><a href="/services#bookkeeping">Bookkeeping</a></li>
            <li><a href="/services#payroll">Payroll</a></li>
            <li><a href="/services#irs">IRS Representation</a></li>
            <li><a href="/services#startups">Business Start-Ups</a></li>
            <li><a href="/services#advisory">Advisory</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-heading">Firm</p>
          <ul>
            <li><a href="/about">About Us</a></li>
            <li><a href="/indian-investors">Indian Investors</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <p class="footer-heading">Contact</p>
          <address class="footer-address">
            <p>1121 Boyce Road, Suite 800A<br />Pittsburgh, PA 15241</p>
            <p><a href="tel:4127201313">412-720-1313</a></p>
            <p><a href="mailto:basupancholillc@gmail.com">basupancholillc@gmail.com</a></p>
            <p class="footer-hours">Mon - Fri | 9am - 6pm</p>
          </address>
        </div>
      </div>

      <div class="container footer-bottom">
        <p>&copy; {new Date().getFullYear()} Basu Pancholi LLC. All rights reserved.</p>
        <div class="footer-social">
          <a href="https://www.facebook.com/basupancholillc/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://twitter.com/BasuPancholiCPA" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://www.youtube.com/channel/UCas_sedCruUO2DiHJsHTboA" target="_blank" rel="noopener noreferrer" aria-label="YouTube">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814z"/><polygon fill="var(--navy)" points="9.545,15.568 15.818,12 9.545,8.432"/></svg>
          </a>
        </div>
      </div>
    </footer>

    <script>
      // Mobile nav toggle
      const toggle = document.querySelector('.menu-toggle');
      const nav = document.querySelector('.main-nav');
      if (toggle && nav) {
        toggle.addEventListener('click', () => {
          const expanded = toggle.getAttribute('aria-expanded') === 'true';
          toggle.setAttribute('aria-expanded', String(!expanded));
          nav.classList.toggle('is-open');
          document.body.style.overflow = !expanded ? 'hidden' : '';
        });
        // Close on link click
        nav.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            toggle.setAttribute('aria-expanded', 'false');
            nav.classList.remove('is-open');
            document.body.style.overflow = '';
          });
        });
      }

      // Header scroll effect
      const header = document.getElementById('site-header');
      if (header) {
        let lastY = 0;
        const onScroll = () => {
          const y = window.scrollY;
          header.classList.toggle('scrolled', y > 80);
          header.classList.toggle('hidden', y > lastY && y > 300);
          lastY = y;
        };
        window.addEventListener('scroll', onScroll, { passive: true });
      }
    </script>
  </body>
</html>

<style>
  /* ===== SKIP TO CONTENT ===== */
  .skip-to-content {
    position: absolute;
    top: -100%;
    left: 50%;
    transform: translateX(-50%);
    z-index: 200;
    padding: 0.75rem 1.5rem;
    background: var(--gold);
    color: var(--navy);
    font-weight: 600;
    font-size: var(--text-sm);
    text-decoration: none;
  }

  .skip-to-content:focus {
    top: 1rem;
  }

  /* ===== HEADER ===== */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 1.25rem 0;
    transition: all var(--duration-base) var(--ease-out);
    background: transparent;
  }

  .site-header.scrolled {
    background: oklch(0.14 0.02 260 / 0.92);
    backdrop-filter: blur(16px);
    padding: 0.75rem 0;
    border-bottom: 1px solid oklch(0.72 0.12 75 / 0.15);
  }

  .site-header.hidden {
    transform: translateY(-100%);
  }

  .header-inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-pad);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo */
  .logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .logo-mark {
    font-family: var(--font-display);
    font-size: 1.6rem;
    letter-spacing: 0.05em;
    color: var(--cream);
  }

  .logo-bar {
    color: var(--gold);
    font-weight: 300;
  }

  .logo-text {
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cream-dim);
    display: none;
  }

  @media (min-width: 768px) {
    .logo-text { display: block; }
  }

  /* Nav */
  .main-nav {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .nav-list {
    display: flex;
    gap: 0.25rem;
  }

  .nav-list a {
    display: block;
    padding: 0.5rem 1rem;
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--cream-dim);
    letter-spacing: 0.03em;
    transition: color var(--duration-fast);
    position: relative;
  }

  .nav-list a:hover,
  .nav-list a.active {
    color: var(--gold);
  }

  .nav-list a.active::after {
    content: '';
    position: absolute;
    bottom: 0.25rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: var(--gold);
  }

  .nav-cta {
    font-size: 0.75rem !important;
    padding: 0.6em 1.4em !important;
    min-height: 44px;
    display: inline-flex;
    align-items: center;
  }

  /* Hamburger */
  .menu-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
  }

  .menu-bar {
    display: block;
    width: 24px;
    height: 1.5px;
    background: var(--cream);
    transition: all var(--duration-fast) var(--ease-out);
    transform-origin: center;
  }

  .menu-toggle[aria-expanded="true"] .menu-bar:first-child {
    transform: translateY(3.75px) rotate(45deg);
  }

  .menu-toggle[aria-expanded="true"] .menu-bar:last-child {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  @media (max-width: 899px) {
    .menu-toggle {
      display: flex;
      position: relative;
      z-index: 200;
    }

    .main-nav {
      position: fixed;
      inset: 0;
      background: var(--charcoal);
      flex-direction: column;
      justify-content: center;
      align-items: center;
      gap: 2rem;
      opacity: 0;
      pointer-events: none;
      transition: opacity var(--duration-base) var(--ease-out);
      z-index: 99;
    }

    .main-nav.is-open {
      opacity: 1;
      pointer-events: all;
    }

    .nav-list {
      flex-direction: column;
      align-items: center;
      gap: 0.5rem;
    }

    .nav-list a {
      font-size: var(--text-xl);
      font-family: var(--font-display);
      padding: 0.75rem 1.5rem;
    }
  }

  /* ===== FOOTER ===== */
  .site-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-xl);
    background: var(--charcoal);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
    padding-block: var(--space-lg);
  }

  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: 1.5fr 1fr 1fr 1.5fr;
    }
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-logo {
    font-size: 2rem;
  }

  .footer-tagline {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--cream-dim);
    font-size: var(--text-base);
    line-height: 1.5;
  }

  .footer-heading {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--gold);
    margin-bottom: 1rem;
  }

  .footer-col ul {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col a,
  .footer-col p {
    font-size: var(--text-sm);
    color: var(--cream-dim);
    transition: color var(--duration-fast);
    line-height: 1.6;
  }

  .footer-col a:hover {
    color: var(--gold);
  }

  .footer-hours {
    margin-top: 0.5rem;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--slate);
  }

  .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-block: 1.5rem;
    border-top: 1px solid oklch(0.30 0.02 260);
  }

  .footer-bottom p {
    font-size: var(--text-xs);
    color: var(--slate);
  }

  .footer-social {
    display: flex;
    gap: 1rem;
  }

  .footer-social a {
    color: var(--slate);
    transition: color var(--duration-fast);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
  }

  .footer-social a:hover {
    color: var(--gold);
  }

  .footer-address {
    font-style: normal;
  }
</style>
